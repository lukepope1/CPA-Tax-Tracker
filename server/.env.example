# --- Server environment variables ---

# Database connection.
# Local dev (SQLite):
DATABASE_URL="file:./dev.db"
# Production (Render Postgres) is set in the Render dashboard, e.g.
# DATABASE_URL="postgresql://user:pass@host:5432/dbname"

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET="change-me-to-a-long-random-string"

# Where the frontend is served from (used for CORS).
# Local:
CLIENT_ORIGIN="http://localhost:5180"
# Production: your Render static site URL, e.g.
# CLIENT_ORIGIN="https://cpa-tax-tracker-web.onrender.com"

# Port the API listens on. Render sets this automatically in production.
PORT=4100
